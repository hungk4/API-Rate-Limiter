{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "RateLimiter.Api.Middleware.RateLimitMiddleware": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Redis": "localhost:6379"
  },
  "AllowedHosts": "*",
  "RateLimit": {
    "Enabled": true,
    "Algorithm": "TokenBucket",
    "Limit": 10,
    "WindowSeconds": 60,
    "RefillPerSecond": 2,
    "ClientKeySource": "IP",
    "ExcludedPaths": [
      "/health",
      "/metrics"
    ],
    "InternalServiceHeader": "X-Internal-Secret",
    "InternalServiceSecret": "my-super-secret-key-2024",
    "Routes": [
      {
        "Path": "/api/upload",
        "Algorithm": "FixedWindow",
        "Limit": 3,
        "WindowSeconds": 60
      },
      {
        "Path": "/api/search",
        "Algorithm": "TokenBucket",
        "Limit": 30,
        "RefillPerSecond": 5
      }
    ]
  }
}