{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "RateLimiter.Api.Middleware.RateLimitMiddleware": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Redis": "localhost:6379"
  },
  "AllowedHosts": "*",
  "RateLimit": {
    "Enabled": true,
    "Algorithm": "TokenBucket",
    "Limit": 10,
    "WindowSeconds": 60,
    "RefillPerSecond": 2,
    "ClientKeySource": "IP",
    "ExcludedPaths": [
      "/health",
      "/metrics"
    ],
    "InternalServiceHeader": "X-Internal-Secret",
    "InternalServiceSecret": "my-super-secret-key-2024",
    "Routes": [
      {
        "Path": "/api/FixedWindow",
        "Algorithm": "FixedWindow",
        "Limit": 3,
        "WindowSeconds": 60
      },
      {
        "Path": "/api/TokenBucket",
        "Algorithm": "TokenBucket",
        "Limit": 8,
        "RefillPerSecond": 1
      },
      {
        "Path": "/api/LeakyBucket",
        "Algorithm": "LeakyBucket",
        "Limit": 4,
        "RefillPerSecond": 0.5
      },
      {
        "Path": "/api/RedisFixedWindow",
        "Algorithm": "RedisFixedWindow",
        "Limit": 5,
        "WindowSeconds": 60
      },
      {
        "Path": "/api/RedisTokenBucket",
        "Algorithm": "RedisTokenBucket",
        "Limit": 8,
        "RefillPerSecond": 1
      },
      {
        "Path": "/api/RedisLeakyBucket",
        "Algorithm": "RedisLeakyBucket",
        "Limit": 4,
        "RefillPerSecond": 0.5
      }
    ]
  }
}