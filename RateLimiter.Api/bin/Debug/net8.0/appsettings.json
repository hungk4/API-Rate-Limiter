{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "RateLimiter.Api.Middleware.RateLimitMiddleware": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Redis": "localhost:6379"
  },
  "AllowedHosts": "*",
  "RateLimit": {
    "Enabled": true,
    "Algorithm": "TokenBucket",
    "Limit": 10,
    "WindowSeconds": 60,
    "RefillPerSecond": 2,
    "ClientKeySource": "IP",
    "ExcludedPaths": ["/health", "/metrics"]
  }
}
